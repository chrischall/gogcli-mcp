{
  "private": true,
  "version": "2.0.3",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm test --workspaces",
    "typecheck": "npm run typecheck --workspaces",
