{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gogcli-connector",
  "main": "packages/gogcli-mcp/src/worker.ts",
  "compatibility_date": "2025-11-01",
  "compatibility_flags": ["nodejs_compat"],
  // One Durable Object per MCP endpoint (worker.ts). Each agent class holds a
  // distinct tool set: MCP_OBJECT = all-services base (/mcp); the per-service
  // ones = auth + <service> base + <service> extras (/mcp/<service>). The
  // connector is otherwise stateless (every gog call is forwarded to
  // FLY_ENDPOINT), so these DOs hold only the per-session MCP transport state.
  "durable_objects": {
    "bindings": [
      { "name": "MCP_OBJECT", "class_name": "GogcliMcpAgent" },
      { "name": "SHEETS_MCP", "class_name": "GogcliSheetsAgent" },
      { "name": "GMAIL_MCP", "class_name": "GogcliGmailAgent" },
      { "name": "DRIVE_MCP", "class_name": "GogcliDriveAgent" },
      { "name": "DOCS_MCP", "class_name": "GogcliDocsAgent" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["GogcliMcpAgent"] },
    {
      "tag": "v2",
      "new_sqlite_classes": ["GogcliSheetsAgent", "GogcliGmailAgent", "GogcliDriveAgent", "GogcliDocsAgent"]
    }
  ],
  // gogcli-connector's own OAuth token store (title: gogcli-connector-oauth).
  // Kept separate from any other connector's OAUTH_KV so their OAuth
  // grants/tokens never cross-wire.
  //
  // The placeholder below is DELIBERATE — leave it in place. `npm run
  // worker:deploy` substitutes the real id at deploy time into a gitignored
  // wrangler.generated.jsonc, so this file stays free of an account-identifying
  // id and there is no edit to revert. Deploying with plain `wrangler deploy`
  // will fail here; use the npm script. For a fresh deployment create the
  // namespace (`wrangler kv namespace create gogcli-connector-oauth`) and pass
  // its id via $OAUTH_KV_ID — see docs/DEPLOY-CONNECTOR.md.
  "kv_namespaces": [
    { "binding": "OAUTH_KV", "id": "REPLACE_WITH_OAUTH_KV_NAMESPACE_ID" }
  ],
  // Production custom domain. The zone must be in the deploying account's
  // Cloudflare; wrangler provisions the hostname on deploy (TLS a few minutes
  // later). Remove this route to deploy to *.workers.dev only.
  "routes": [{ "pattern": "connector.gogcli.nullnet.app", "custom_domain": true }],
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  // The Fly.io backend that actually runs `gog` (built in a prior PR). Each
  // forwarded arg-array is POSTed to `<FLY_ENDPOINT>/run` with the user's
  // connector key as a bearer token. Replace with your deployed Fly URL.
  "vars": {
    "FLY_ENDPOINT": "https://gogcli-gog-runner.fly.dev"
  }
}
