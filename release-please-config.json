    {
      "type": "refactor",
      "section": "Refactor"
    },
    {
      "type": "docs",
      "section": "Documentation"
    },
    {
      "type": "test",
      "section": "Tests",
      "hidden": true
    },
    {
      "type": "build",
      "section": "Build",
      "hidden": true
    },
    {
      "type": "ci",
      "section": "CI",
      "hidden": true
    },
    {
      "type": "chore",
      "section": "Chores",
      "hidden": true
    }
  ],
